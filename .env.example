DATABASE_URL="file:./prisma/dev.db"
AUTH_SECRET="change-this-to-a-long-random-string-in-production"

# Optional SMTP for forgot-password emails (if unset, codes print in dev server console)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="EXAM DESK <your-email@gmail.com>"